# Sidekick Chat Configuration

# Port to run on
PORT=3847

# Clawdbot session ID (isolates this chat from other sessions)
CLAWDBOT_SESSION_ID=sidekick-chat

# Path to avatar images (optional)
# AVATARS_DIR=/path/to/avatars

# Clawdbot workspace directory (where SOUL.md, MEMORY.md etc. live)
# CLAWD_DIR=/path/to/clawd/workspace
