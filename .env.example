# Sidekick Chat Configuration
# Copy this to .env and customize for your setup

# Port to run on (default: 3847)
PORT=3847

# Clawdbot session ID - isolates this chat from other sessions (Telegram, etc.)
# Change this if you want a unique session name
CLAWDBOT_SESSION_ID=sidekick-chat

# Project directory - where inbox/outbox folders live
# Default: current working directory (usually fine to leave unset)
# PROJECT_DIR=/path/to/sidekick-chat

# Clawdbot workspace directory - where SOUL.md, MEMORY.md, avatars/ etc. live
# Default: ~/clawd
# CLAWD_DIR=/Users/yourname/clawd

# Path to avatar images (optional)
# Default: $CLAWD_DIR/avatars
# AVATARS_DIR=/path/to/avatars
